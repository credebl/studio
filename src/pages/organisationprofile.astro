---
interface UserObject {
    Ledger: string;
    DID: string;
    Network: string;
    WalletName: string;
    CreationDate: string;
    Role: string[];  
}
const userObj:UserObject={
	Ledger:"AyanWorks",
	DID:"5usiJ7bsGG7s9wuwJ",
	Network:"Indicio TestNet",
	WalletName:"Global Giving",
	CreationDate:  Date.now().toLocaleString(),
	Role:["Issuer, Verifier"]
}
import QRCode from "react-qr-code";
---

<!-- header  -->
<div class="">
	<div class="w-full mx-0 ">
		<div class="flex px-3 py-2 justify-end">
			<div class="flex items-center justify-end">
				<!-- <a class="flex mr-4" href='/'>
					<img
						src='/images/CREDEBL_ICON.png'
						class="h-8 mr-3"
						alt="CREDEBL Logo"
					/> -->
					
					<svg class="w-6 h-6 text-gray-800 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 16 21">
						<path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 3.464V1.1m0 2.365a5.338 5.338 0 0 1 5.133 5.368v1.8c0 2.386 1.867 2.982 1.867 4.175C15 15.4 15 16 14.462 16H1.538C1 16 1 15.4 1 14.807c0-1.193 1.867-1.789 1.867-4.175v-1.8A5.338 5.338 0 0 1 8 3.464ZM4.54 16a3.48 3.48 0 0 0 6.92 0H4.54Z"/>
				</svg>
					<span
						class="self-center text-2xl  px-2 mx-2 whitespace-nowrap dark:text-white"
						>John Doe...</span
					>
					<div class="relative w-8 h-8 overflow-hidden bg-gray-100 rounded-full dark:bg-gray-600">
						<svg class="absolute w-10 h-10 text-gray-400 -left-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path></svg>
				</div>
				<!-- </a> -->
				</div> 
			</div>
</div>

<div class="grid grid-cols-3 gap-4 p-2 bg-gray-100">
  <div class="h-screen col-span-1 border">
		<div class="w-full h-full bg-white rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
			<div class="flex  flex-col items-center pb-10">
					<img class=" w-56 h-56 my-4 rounded-full shadow-lg" src="/docs/images/people/profile-picture-3.jpg" alt="Bonnie image"/>
					<h3 class="mb-1 text-3xl font-medium text-gray-900 dark:text-white">John Doe</h3>
					<div class="flex text-center align-middle ">
						<svg class="w-6 h-6 text-gray-800 dark:text-white m-0.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 16">
							<path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m19 2-8.4 7.05a1 1 0 0 1-1.2 0L1 2m18 0a1 1 0 0 0-1-1H2a1 1 0 0 0-1 1m18 0v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2"/>
						</svg>
						<span class="text-2xl text-gray-500 dark:text-gray-400 pl-2 ">Johndoe@yopmail.com</span>
					</div>
			</div>
		</div>
  </div>

  <div class="col-span-2 grid grid-rows-2 gap-4  bg-gray-100 ">
    <div class="grid grid-cols-2  rounded gap-2 bg-white">
      <div class="col-span-1">
				<h1 class="font-semibold text-2xl p-3">Wallet Details</h1>
			<div class=" flex justify-start align-middle items-center p-3">
				<ul class="space-y-6">
					{Object.entries(userObj).map(([key, value]) => (
						<li class="flex items-center text-xl">
							<span class=" w-52">{key}</span>
                            <span class="mx-2">:</span>
                            <span class="ml-9 text-gray-600">{value}</span>
						</li>
					))}
			</ul>
			</div>
			</div>
			<div class="col-span-1"> 
				<div class="h-auto max-w-64 w-full flex flex-col items-center">
					<div
							class="bg-white p-4 border border-gray-200 rounded-lg shadow-sm dark:border-gray-700 overflow-hidden">
							<QRCode
									size={180}
									value="www.ayanworks.com"
							/>
							<p class="text-center text-base mt-4">SCAN TO CONNECT</p>
					</div>
					<p class="text-center mt-3">OR</p>
					<p class="text-center mt-3 ">Invitation URL</p>
					<div class="flex items-center text-center mt-1">
							<p class="md: w-[240px] break-all truncate">dummy data</p>
							<button
									<svg class="h-6 w-6 text-white ml-3 text-base stroke-green-400 "  stroke-width="2"  stroke-linecap="round" stroke-linejoin="round">  <path stroke="none" d="M0 0h24v24H0z" />  <path d="M5 12l5 5l10 -10" /></svg>
							</button>
					</div>
					<button
							class="text-sm content-center px-5 py-2.5 mt-6 text-base font-medium text-center text-white bg-primary-700 rounded-lg hover:bg-primary-800 focus:ring-4 focus:ring-primary-300 sm:w-auto dark:bg-primary-600 dark:hover:bg-primary-700 dark:focus:ring-primary-800"
					>
							Download
					</button>
			</div>
			</div>
    </div>

    <div class="p-2  rounded bg-white">
			<h1 class="font-bold text-2xl p-2">Users</h1>
			<div class=" grid lg:grid-cols-2 sm:grid-cols-1  gap-2  rounded  ">
				<div class="px-6 py-4 col-span-1 bg-gradient-to-r from-white via-white to-gray-50 hover:bg-gradient-to-br focus:ring-4 focus:outline-none focus:ring-gray-300 dark:focus:ring-gray-800 shadow-lg shadow-gray-500/50 dark:shadow-lg dark:shadow-gray-800/80 rounded-lg  ">
					<div class="flex  ">
						<svg class="w-6 h-6 text-gray-800 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 20">
							<path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19a9 9 0 1 0 0-18 9 9 0 0 0 0 18Zm0 0a8.949 8.949 0 0 0 4.951-1.488A3.987 3.987 0 0 0 11 14H9a3.987 3.987 0 0 0-3.951 3.512A8.948 8.948 0 0 0 10 19Zm3-11a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
						</svg>
						<div class="font-bold text-xl pl-2 mb-2">Name</div>
					</div>
					<div class="flex">
						<svg class="w-6 h-6 text-gray-800 dark:text-white m-0.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 16">
							<path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m19 2-8.4 7.05a1 1 0 0 1-1.2 0L1 2m18 0a1 1 0 0 0-1-1H2a1 1 0 0 0-1 1m18 0v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2"/>
						</svg>
					<p class="text-gray-700 text-xl pl-1">email@example.com</p>

					</div>
					<a
					href="/organizations"
					class="float-right inline-flex items-center p-2 text-sm font-medium rounded-lg text-primary-700 hover:bg-gray-100 dark:text-primary-500 dark:hover:bg-gray-700"
				>
					View More..
				</a>
				</div>
				<div class="px-6 py-4 col-span-1 bg-gradient-to-r from-white via-white to-gray-50 hover:bg-gradient-to-br focus:ring-4 focus:outline-none focus:ring-gray-300 dark:focus:ring-gray-800 shadow-lg shadow-gray-500/50 dark:shadow-lg dark:shadow-gray-800/80 rounded-lg  ">
