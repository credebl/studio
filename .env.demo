# Please provide your developement environment
NEXT_PUBLIC_MODE=DEV
# URL where platform is running 
NEXT_PUBLIC_BASE_URL=http://localhost:5000
NEXT_PUBLIC_ECOSYSTEM_FRONT_END_URL= # Ecosystem front end URL
CRYPTO_PRIVATE_KEY= # Crypto private It should be same as platform 
NEXT_PUBLIC_PLATFORM_NAME=CREDEBL

NEXT_PUBLIC_POLYGON_TESTNET_URL='https://rpc-amoy.polygon.technology/'
NEXT_PUBLIC_POLYGON_MAINNET_URL='https://polygon-rpc.com/'
PUBLIC_PLATFORM_DOCS_URL=https://docs.credebl.id/en/intro/what-is-credebl/

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET= #Generate this secret by referring https://next-auth.js.org/configuration/options#nextauth_secret.
NEXTAUTH_COOKIE_DOMAIN=localhost
NEXTAUTH_PROTOCOL=http

PUBLIC_ALLOW_DOMAIN="http://your-ip:5000 http://localhost:5000 http://localhost:5001 http://your-ip:5001 https://cdnjs.cloudflare.com https://tailwindcss.com https://fonts.googleapis.com https://fonts.gstatic.com https://avatars.githubusercontent.com https://flowbite-admin-dashboard.vercel.app/ http://your-ip:3001 http://localhost:3001 http://localhost:3000/certificates ws://your-ip:5000 ws://localhost:5000 https://rpc-amoy.polygon.technology/"

# App Launcher Variables
# Please provide true if you want to enable app launcher else false
NEXT_PUBLIC_ENABLE_APP_LAUNCHER=false
# Please provide your app name here
NEXT_PUBLIC_APP_NAME=CREDEBL Studio
# Set true if you want to enable social login else false
NEXT_PUBLIC_ENABLE_SOCIAL_LOGIN=false
# Set true if you want to enable billing option else false
NEXT_PUBLIC_ENABLE_BILLING_OPTION=false

# Theme related Variable
# Please provide your active theme name here
NEXT_PUBLIC_ACTIVE_THEME=CREDEBL
# Please provide your application title here
NEXT_PUBLIC_APP_TITLE=CREDEBL Studio
NEXT_PUBLIC_FOOTER_TEXT= # Please provide your application footer text here


NEXT_PUBLIC_LOGO_BASE_URL= # Please provide your logo base URL here
NEXT_PUBLIC_ADMIN_PORTAL_CLIENT_ID= # Please provide the clientId for admin portal


NEXT_PUBLIC_LANDINGPAGE_URL= # URL for the Sovio landing page
# Fixed OpenSSL header value required by the application. Use this exact value.
OPENSSL_HEADER=53616c7465645f5f
PUBLIC_ECOSYSTEM_BASE_URL= # Base URL for the public ecosystem services/API
# Current runtime mode (e.g. DEV, QA, PROD)
MODE=DEV
NEXT_PUBLIC_CURRENT_RELEASE= # Current release/version
